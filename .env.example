# Ramaria 运行时配置
# 复制此文件为 .env 并填写实际值
# 注意: .env 文件不会上传到 Git

# =============================================================================
# 应用基础配置
# =============================================================================
APP_NAME=Ramaria
APP_DEBUG=true

# =============================================================================
# 本地模型配置 (必须)
# =============================================================================
# 本地推理服务地址 (LM Studio / Ollama 等)
LOCAL_API_URL=http://localhost:1234/v1/chat/completions

# 模型标识符 (需与推理服务中的模型名称匹配)
LOCAL_MODEL_NAME=qwen/qwen3.5-9b

# 对话模型温度 (0.0-1.0，越低越确定性)
LOCAL_TEMPERATURE=0.3

# 摘要类任务最大 token 数
LOCAL_MAX_TOKENS_SUMMARY=512

# 对话类任务最大 token 数
LOCAL_MAX_TOKENS_CHAT=1024

# =============================================================================
# 嵌入模型配置 (必须)
# =============================================================================
# 嵌入模型本地路径 (支持 absolute path 或相对于项目根目录)
EMBEDDING_MODEL_PATH=./models/embedding-model

# =============================================================================
# 云端模型配置 (可选)
# =============================================================================
# Claude API Key (用于复杂推理任务)
# 申请地址: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxxx

# Claude 模型标识符
CLAUDE_MODEL_NAME=claude-sonnet-4-20250514

# Claude 最大 token 数
CLAUDE_MAX_TOKENS=2048

# Claude 温度
CLAUDE_TEMPERATURE=0.7

# =============================================================================
# 服务器配置
# =============================================================================
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# =============================================================================
# 数据目录 (可选，使用默认目录可跳过)
# =============================================================================
# DATA_DIR=./data
# CONFIG_DIR=./config
# LOG_DIR=./logs

# =============================================================================
# 记忆系统配置 (可选，使用默认配置可跳过)
# =============================================================================
# L1 摘要触发空闲时间 (分钟)
# L1_IDLE_MINUTES=10

# L2 合并触发条数
# L2_TRIGGER_COUNT=5

# 语义相似度阈值 (0-1)
# SIMILARITY_THRESHOLD=0.6
