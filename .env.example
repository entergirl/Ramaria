# Ramaria 运行时配置
# 复制此文件为 .env 并填写实际值
# 注意: .env 文件不会上传到 Git

# =============================================================================
# 应用基础配置
# =============================================================================
APP_NAME=Ramaria
APP_DEBUG=true

# =============================================================================
# 本地模型配置 (必须)
# =============================================================================
# 本地推理服务地址 (LM Studio / Ollama 等)
LOCAL_API_URL=http://localhost:1234/v1/chat/completions

# 模型标识符 (需与推理服务中的模型名称匹配)
LOCAL_MODEL_NAME=qwen/qwen3.5-9b

# 对话模型温度 (0.0-1.0，越低越确定性)
LOCAL_TEMPERATURE=0.3

# 摘要类任务最大 token 数
LOCAL_MAX_TOKENS_SUMMARY=512

# 对话类任务最大 token 数
LOCAL_MAX_TOKENS_CHAT=1024

# =============================================================================
# 嵌入模型配置 (必须)
# =============================================================================
# 嵌入模型本地路径 (支持 absolute path 或相对于项目根目录)
# 
# 关键说明：
#   · 此配置项 **必填**，应用启动时会验证路径有效性
#   · 如果路径无效，应用启动会失败（或降级运行，向量检索功能不可用）
#   · 运行中可通过 API /api/model-path POST 接口热修改此值
#   · 修改后会自动更新本 .env 文件
#
# 可选值示例：
#   - EMBEDDING_MODEL=./models/embedding-model  (相对路径)
#   - EMBEDDING_MODEL=/opt/models/embedding-model  (绝对路径)
#   - EMBEDDING_MODEL=default  (chromadb 内置默认模型，不推荐，需要 onnxruntime)
#
# 模型目录必须包含以下文件之一：
#   - config.json + .onnx 文件 (ONNX 格式)
#   - config.json + pytorch_model.bin (PyTorch 格式)
#
# 注意事项：
#   · 不支持从 HuggingFace 自动下载，必须提前下载到本地
#   · 打包后（exe 模式）向量模型不包含在内，需要用户单独管理
#
EMBEDDING_MODEL=./models/embedding-model

# =============================================================================
# 云端模型配置 (可选)
# =============================================================================
# Claude API Key (用于复杂推理任务)
# 申请地址: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxxx

# Claude 模型标识符
CLAUDE_MODEL_NAME=claude-sonnet-4-20250514

# Claude 最大 token 数
CLAUDE_MAX_TOKENS=2048

# Claude 温度
CLAUDE_TEMPERATURE=0.7

# =============================================================================
# 服务器配置
# =============================================================================
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# =============================================================================
# 数据目录 (可选，使用默认目录可跳过)
# =============================================================================
# DATA_DIR=./data
# CONFIG_DIR=./config
# LOG_DIR=./logs

# =============================================================================
# 记忆系统配置 (可选，使用默认配置可跳过)
# =============================================================================
# L1 摘要触发空闲时间 (分钟)
# L1_IDLE_MINUTES=10

# L2 合并触发条数
# L2_TRIGGER_COUNT=5

# 语义相似度阈值 (0-1)
# SIMILARITY_THRESHOLD=0.6

# =============================================================================
# 天气查询配置 (可选)
# =============================================================================
# 留空时自动通过 IP 定位当前城市（推荐）
# 填写后将优先使用此值，推荐使用英文城市名以确保 wttr.in 识别准确
# 示例：WEATHER_CITY=Shanghai
WEATHER_CITY=